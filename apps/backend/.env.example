# SAGE Backend v3 — environment.
# SECURITY: these upstream keys live ONLY on the server. They are NEVER sent to
# the device. The mobile client always routes cloud inference through this
# backend and never contacts OpenRouter / Tavily / E2B directly.

# Port
PORT=8787

# Upstream inference provider: mock | openrouter | azure-foundry
# 'mock' requires no keys and is the default — the app runs end-to-end offline-style.
SAGE_UPSTREAM_PROVIDER=mock

# OpenAI-compatible upstream (used for openrouter AND azure-foundry)
# OpenRouter:
#   SAGE_UPSTREAM_PROVIDER=openrouter
#   SAGE_UPSTREAM_BASE_URL=https://openrouter.ai/api/v1
#   SAGE_UPSTREAM_API_KEY=sk-or-...
# Azure AI Foundry (OpenAI-compatible; auth via 'api-key' header):
#   SAGE_UPSTREAM_PROVIDER=azure-foundry
#   SAGE_UPSTREAM_BASE_URL=https://<resource>.openai.azure.com
#   SAGE_AZURE_API_VERSION=2024-10-21
#   SAGE_UPSTREAM_API_KEY=<azure-key>
SAGE_UPSTREAM_BASE_URL=
SAGE_UPSTREAM_API_KEY=
SAGE_AZURE_API_VERSION=2024-10-21

# Comma-separated allowlist of models the server will proxy (Constraint 2).
SAGE_ALLOWED_MODELS=mock-cloud,anthropic/claude-sonnet-4,google/gemini-2.5-pro,openai/o3,perplexity/sonar

# Cloud tool runtime keys (POST /api/sage/tools/*)
TAVILY_API_KEY=
JINA_API_KEY=
E2B_API_KEY=

# SSE heartbeat interval in ms (0 disables the interval; an immediate heartbeat is always sent)
SAGE_HEARTBEAT_MS=15000
