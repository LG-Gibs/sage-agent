  },
  "dependencies": {
    "expo": "~51.0.39",
    "expo-av": "~14.0.7",
    "expo-battery": "~8.0.1",
    "expo-build-properties": "~0.12.5",
    "expo-dev-client": "~4.0.29",
    "expo-network": "~6.0.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "@react-native-community/netinfo": "11.3.1",
    "@picovoice/porcupine-react-native": "^3.0.3",
    "react-native-mmkv": "^2.12.2",
    "llama.rn": "^0.4.5",
    "whisper.rn": "^0.4.0",
    "react-native-quickjs": "^0.2.0",
    "@sage/shared-types": "file:../../packages/shared-types",
    "@sage/arbiter-core": "file:../../packages/arbiter-core",
    "@sage/tool-registry": "file:../../packages/tool-registry",
    "@sage/sse-contract": "file:../../packages/sse-contract",
