{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@sage/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@sage/arbiter-core": ["../../packages/arbiter-core/src/index.ts"],
      "@sage/tool-registry": ["../../packages/tool-registry/src/index.ts"],
      "@sage/sse-contract": ["../../packages/sse-contract/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
