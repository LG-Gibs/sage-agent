# Dependencies
node_modules/
.pnp.*
.yarn/*

# Build output
dist/
build/
*.tsbuildinfo

# Test / coverage
coverage/
.vitest/

# Env & secrets — NEVER commit upstream API keys
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# ── React Native / Expo (apps/mobile) ──
apps/mobile/node_modules/
apps/mobile/.expo/
apps/mobile/dist/
apps/mobile/web-build/

# iOS — generated by `expo prebuild`; only checked-in config is tracked
apps/mobile/ios/Pods/
apps/mobile/ios/build/
apps/mobile/ios/*.xcworkspace/xcuserdata/
apps/mobile/ios/DerivedData/

# Android — generated by `expo prebuild`
apps/mobile/android/.gradle/
apps/mobile/android/build/
apps/mobile/android/app/build/
apps/mobile/android/local.properties

# GGUF model weights — large; never committed to git
*.gguf
models/

# Native voice assets
*.onnx
*.ppn
